					"leg4.ty": "23.5 +(3.5 +3*limb_speed)*var.air +clamp(sin(torad(-90)+var.ls)*6*limb_speed, -6, 0)*(1-var.air) +15*var.die",
					"leg3.ty": "23.5 +(3.5 +3*limb_speed)*var.air +clamp(sin(torad( 90)+var.ls)*6*limb_speed, -6, 0)*(1-var.air) +15*var.die",
