					"leg3.tz": "3.7 +asin(sin(var.ls))*2.5*clamp(limb_speed*6, 0, 1)*(1-var.air)",
					"leg4_2.rz": "if(age>10, clamp(cos(var.r+ rot_y*9)*(clamp(-(rot_y-var.turn)*var.fps*2, 0, 1) +clamp((rot_y-var.turn)*var.fps*2, 0, 1)), -0.3, 0)*clamp(1-limb_speed*4, 0, 1-var.air) +clamp((pos_y-var.jump)*var.fps*var.air, -pi/4, pi/4), 0) +(-sin(var.als)/5)*(1+limb_speed)*var.air",
