					"right_arm.tz": "0-sin((limb_swing/5)/if(is_child, 45, 80)*pi*2)/4 -1 +torad(head_yaw) -(sin(pi*swing_progress)*4)-(1*limb_speed)",
					"left_arm.tz": " 0-sin((limb_swing/5)/if(is_child, 45, 80)*pi*2)/4 -1 -torad(head_yaw) -(sin(pi*swing_progress)*4)-(1*limb_speed)"
