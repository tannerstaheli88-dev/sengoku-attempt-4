					"right_ear.rx": "sin(torad(-45)+var.b)/15 +sin(torad(90)+var.ls*2)/6*limb_speed*var.walk +(-sin(var.lsj)/5)*limb_speed*var.run +torad(head_pitch)/2 +clamp((-47 +sin(          var.r+age/26*2)*48)*clamp(-32 +cos(          (var.r+age/26)/1.5)*40 +cos(          (var.r+age/26)/4)*40, 0, 1), 0, 1)/2",
