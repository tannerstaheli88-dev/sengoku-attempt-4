					"render.leash_offset_y": "-(head2.ty +if(is_child, 8, 0))/16/if(is_child, 2, 1)",
					"render.leash_offset_z": "-(head2.tz -1                 )/16/if(is_child, 2, 1)"
				},
				{
					"leg1.rx": " sin(var.b)/60 +if(!is_on_ground&&is_in_water,  sin(var.swim)/2, ((asin(sin(torad(-90+20)+var.ls))/4 +torad( 10))*clamp(limb_speed*8, 0.4, 1) +clamp(sin(torad( 0 +20)+var.ls)/3, torad(-30), 0)*if(is_child, 1.5, 1)*clamp(limb_speed*8, 0, 1))*var.walk +(-sin(pi/4 +var.lsj -sin(var.lsj)/3)/3 +torad(10) )*limb_speed*var.run ) -torad(5)",
					"leg2.rx": " sin(var.b)/60 +if(!is_on_ground&&is_in_water, -sin(var.swim)/2, ((asin(sin(torad( 90+20)+var.ls))/4 +torad( 10))*clamp(limb_speed*8, 0.4, 1) +clamp(sin(torad(180+20)+var.ls)/3, torad(-30), 0)*if(is_child, 1.5, 1)*clamp(limb_speed*8, 0, 1))*var.walk +(-sin(      var.lsj -sin(var.lsj)/3)/3 +torad(10) )*limb_speed*var.run ) -torad(5)",
					"leg3.rx": "-sin(var.b)/60 +if(!is_on_ground&&is_in_water, -sin(var.swim)/2, ((asin(sin(torad(180   )+var.ls))/4 +torad(-10))*clamp(limb_speed*8, 0.4, 1) +clamp(sin(torad( 90   )+var.ls)/3, 0, torad( 30))*if(is_child, 1.5, 1)*clamp(limb_speed*8, 0, 1))*var.walk +(-sin(pi/4 +var.lsj -sin(var.lsj)/3)/3 +torad( 5) )*limb_speed*var.run ) +torad(5)",
					"leg4.rx": "-sin(var.b)/60 +if(!is_on_ground&&is_in_water,  sin(var.swim)/2, ((asin(sin(torad( 0    )+var.ls))/4 +torad(-10))*clamp(limb_speed*8, 0.4, 1) +clamp(sin(torad(-90   )+var.ls)/3, 0, torad( 30))*if(is_child, 1.5, 1)*clamp(limb_speed*8, 0, 1))*var.walk +(-sin(      var.lsj -sin(var.lsj)/3)/3 +torad( 5) )*limb_speed*var.run ) +torad(5)",
					"leg1.ry": "torad( 5 )*clamp(1-limb_speed*8, 0, 1)",
					"leg2.ry": "torad(-5 )*clamp(1-limb_speed*8, 0, 1)",
					"leg3.ry": "torad(-10)*clamp(1-limb_speed*8, 0, 1)",
					"leg4.ry": "torad( 10)*clamp(1-limb_speed*8, 0, 1)",
					"leg1.rz": "if(!is_on_ground&&is_in_water, torad(-10), 0) +if(is_child,  torad(5), 0)",
					"leg2.rz": "if(!is_on_ground&&is_in_water, torad( 10), 0) +if(is_child, -torad(5), 0)",
					"leg3.rz": "if(!is_on_ground&&is_in_water, torad(-10), 0) +if(is_child,  torad(5), 0)",
					"leg4.rz": "if(!is_on_ground&&is_in_water, torad( 10), 0) +if(is_child, -torad(5), 0)",
					"leg1.tx": " 3.5 +if(!is_on_ground&&is_in_water,  1, 0)",
					"leg2.tx": "-3.5 +if(!is_on_ground&&is_in_water, -1, 0)",
					"leg3.tx": " 2.5 +if(!is_on_ground&&is_in_water,  2, 0)",
					"leg4.tx": "-2.5 +if(!is_on_ground&&is_in_water, -2, 0)",
					"leg1.ty": "if(is_child, 25, 24) +if(!is_on_ground&&is_in_water, if(is_ridden, 0, 5) +sin(torad( 90)+var.swim)*1.5, clamp( (-1*limb_speed +sin(torad( 0 +20)+var.ls)*if(is_child, 3, 2)*clamp(limb_speed*8, 0, 1))*var.walk +(-cos(pi/4 +var.lsj)*3 -2.5)*limb_speed*var.run, -6, 0))",
					"leg2.ty": "if(is_child, 25, 24) +if(!is_on_ground&&is_in_water, if(is_ridden, 0, 5) +sin(torad(-90)+var.swim)*1.5, clamp( (-1*limb_speed +sin(torad(180+20)+var.ls)*if(is_child, 3, 2)*clamp(limb_speed*8, 0, 1))*var.walk +(-cos(      var.lsj)*3 -2.5)*limb_speed*var.run, -6, 0))",
					"leg3.ty": "if(is_child, 25, 24) +if(!is_on_ground&&is_in_water, if(is_ridden, 0, 3) +sin(torad(-90)+var.swim)*1.5, clamp( (-1*limb_speed +sin(torad(-90   )+var.ls)*if(is_child, 3, 2)*clamp(limb_speed*8, 0, 1))*var.walk +(-cos(pi/4 +var.lsj)*3 -2.5)*limb_speed*var.run, -6, 0))",
					"leg4.ty": "if(is_child, 25, 24) +if(!is_on_ground&&is_in_water, if(is_ridden, 0, 3) +sin(torad( 90)+var.swim)*1.5, clamp( (-1*limb_speed +sin(torad( 90   )+var.ls)*if(is_child, 3, 2)*clamp(limb_speed*8, 0, 1))*var.walk +(-cos(      var.lsj)*3 -2.5)*limb_speed*var.run, -6, 0))",
					"leg1.tz": " 9 +if(!is_on_ground&&is_in_water,  sin(var.swim)*6, asin(sin(torad(-90+20) +var.ls))*4*clamp(limb_speed*8, 0.4, 1)*var.walk +(-sin(pi/4 +var.lsj -sin(var.lsj)/2)*5 +1)*limb_speed*var.run )",
					"leg2.tz": " 9 +if(!is_on_ground&&is_in_water, -sin(var.swim)*6, asin(sin(torad( 90+20) +var.ls))*4*clamp(limb_speed*8, 0.4, 1)*var.walk +(-sin(      var.lsj -sin(var.lsj)/2)*5 +1)*limb_speed*var.run )",
					"leg3.tz": "-4 +if(!is_on_ground&&is_in_water, -sin(var.swim)*6, asin(sin(torad(180   ) +var.ls))*4*clamp(limb_speed*8, 0.4, 1)*var.walk +(-sin(pi/4 +var.lsj -sin(var.lsj)/2)*5 +1)*limb_speed*var.run )",
					"leg4.tz": "-4 +if(!is_on_ground&&is_in_water,  sin(var.swim)*6, asin(sin(torad( 0    ) +var.ls))*4*clamp(limb_speed*8, 0.4, 1)*var.walk +(-sin(      var.lsj -sin(var.lsj)/2)*5 +1)*limb_speed*var.run )",
