			"animations": [
				{
					"var.r": "random(id)*pi*4",
					"var.ls": "limb_swing*if(is_child, 0.7, 1)",
					"var.lsj": "limb_swing/if(is_child, 2, 1.3)",
					"var.b": "var.r +age/if(is_child, 40, 75)*pi*2",
					"var.swim": "var.r +limb_swing/6 +age/if(is_child, 13, 18)*pi*2",
					"var.run": "clamp(if(limb_speed >= if(is_child, 0.4, 0.7), min(20, var.run +0.1 *frame_time*20), max(0, var.run -0.1 *frame_time*20)), 0, if(is_child, 1.3, 1))",
					"var.walk": "clamp(1-var.run, 0, 1)"
				},
				{
					"head2.rx": "-head.rx +torad(head_pitch)/1.5 -if(!is_on_ground&&is_in_water, torad(-5) +sin(var.swim)/10, cos(var.ls*2)/14*clamp(limb_speed*2, 0, 1)*var.walk -(-cos(var.lsj)/12 -torad(5))*limb_speed*var.run ) +sin(var.b+torad(90))/70 +(torad(10)*limb_speed)",
					"head2.rz": "-head.rz -sin(torad( 0)+var.ls)/20*clamp(limb_speed*2, 0, 1)*var.walk",
					"head2.ry": "-head.ry +sin(torad(90)+var.ls)/16*clamp(limb_speed*2, 0, 1)*var.walk +torad(head_yaw)",
					"head2.tx": "clamp(-torad(head_yaw)*2*if(is_ridden, 0, clamp(1-limb_speed*4, 0, 1)), torad(-2), torad(2))",
					"head2.ty": "-17.5 +if(!is_on_ground&&is_in_water, if(is_ridden, 0, 4) +sin(var.swim), -sin(torad(-45)+var.ls*2)*clamp(limb_speed*2, 0, 1)*var.walk -(cos(+var.lsj -sin(var.lsj)/2)*3 +2)*limb_speed*var.run ) -sin(var.b+torad(90))/4",
					"head2.tz": "-6.5 +if(!is_on_ground&&is_in_water, -sin(torad(-45)+var.swim)/2, (sin(-pi/4 +var.lsj -cos(var.lsj)/3) -1)*limb_speed*var.run)",
					"body_rotation.rx": "if(!is_on_ground&&is_in_water, torad(-10) +sin(var.swim)/10, -sin(var.ls*2)/10*clamp(limb_speed*2, 0, 1)*var.walk +(-sin(var.lsj)/8 +torad(5))*limb_speed*var.run ) +sin(var.b-torad(45))/60",
					"body_rotation.ry": "sin(var.ls)/20*clamp(limb_speed*2, 0, 1)*var.walk",
					"body_rotation.rz": "clamp(-torad(head_yaw)/7*if(is_ridden, 0, clamp(1-limb_speed*4, 0, 1)), torad(-5), torad(5))",
					"body_rotation.tx": "0",
					"body_rotation.ty": "if(!is_on_ground&&is_in_water, sin(torad(-45)+var.swim)/2, sin(torad(-135)+var.ls*2)/4*clamp(limb_speed*2, 0, 1)*var.walk +(sin(-pi/4 +var.lsj) -1)*limb_speed*var.run ) -18.5",
					"body_rotation.tz": "if(!is_on_ground&&is_in_water, if(is_ridden, 0, -5), if(is_ridden, 1, -1)*limb_speed +cos(var.ls)/2*clamp(limb_speed*2, 0, 1)*var.walk +(cos(var.lsj)*3 +3)*limb_speed*var.run ) +2.2 +sin(var.b)/6",
