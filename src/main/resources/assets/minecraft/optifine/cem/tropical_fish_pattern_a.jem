					"body_part.rz": "body2.rz",
					"body_part.tx": "body2.tx",
					"body_part.ty": "body2.ty+6",
					"body_part.tz": "body2.tz+4",
					"body_part.sx": "body2.sx",
					"body_part.sy": "body2.sy",
