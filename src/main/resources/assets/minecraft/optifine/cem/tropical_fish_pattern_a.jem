			"animations": [
				{
					"var.r": "random(id)*pi*4"
				},
				{
					"body_front.ry": "-body_back.ry/3.33",
					"body_front.tx": " body_back.ry*1.92",
					"body2.ry": "    if(is_in_water, sin(var.r+limb_swing+age/12)/5              *(1+limb_speed    ) +torad(head_yaw)/2, -cos(limb_swing+age/2)/8*2)",
					"body3.ry": "    if(is_in_water,-cos(var.r+limb_swing+age/12)/8              *(1+limb_speed*2  ) +torad(head_yaw)/2, -cos(limb_swing+age/2)/8*2)",
					"head2.ry": "    if(is_in_water,(cos(var.r+limb_swing+age/12)/10 -body2.ry/2)*(1+limb_speed*1.5) -torad(head_yaw)/3,  sin(limb_swing+age/2)/6*2)",
					"tail2.ry": "    if(is_in_water,-cos(var.r+limb_swing+age/12)/4              *(1+limb_speed*1.5) +torad(head_yaw)  , -sin(limb_swing+age/2)/3*2)",
					"fin_top.ry": "  if(is_in_water,-cos(var.r+limb_swing+age/12)/16 *(1+limb_speed*1.5)                               , -cos(limb_swing+age/2)/6)",
					"fin_top.rz": "  if(is_in_water,-cos(var.r+limb_swing+age/12)/7  *(1+limb_speed*1.5)                               , -sin(limb_swing+age/2)/2)",
					"body2.tx": "    if(is_in_water, cos(var.r+limb_swing+age/12)/1.6*(1+limb_speed*2  )                               , -cos(limb_swing+age/2))",
					"body2.ty": "0 +if(is_in_water, cos((pos_x*1.5+pos_y*2+pos_z*1.5)+age/17), 0)",
					"body2.tz": "-1 +if(is_in_water, 0, 0)",
					"head2.rx": "torad(-1)",
					"body3.rx": "torad( 1)",
					"body2.rx": "clamp(if(age>4&&var.y!=pos_y, -(pos_y-var.y), 0), -pi/3, pi/3)",
					"body2.rz": "    if(is_in_water, -cos(var.r+limb_swing+age/12)/10 *clamp(limb_speed*1.5, 0, 1), torad(20) +torad(-40)*clamp(limb_speed*6, 0, 1) +sin(limb_swing +sin(limb_swing*2))/2 +limb_swing/2 -torad(90))",
					"body2.sx": "1 +(0.5-random(id))/2.4",
					"body2.sy": "body2.sx",
					"body2.sz": "body2.sx"
				},
				{
					"left_fin.rx": " torad( 20)",
					"right_fin.rx": "torad( 20)",
					"left_fin.ry": " torad(-20) +if(is_in_water, -cos(torad(30)+var.r+limb_swing/2+age/9 +sin(var.r+limb_swing/2+age/18)/2)/2*clamp(1-limb_speed*6, 0, 1)                                                                      , 0)",
					"right_fin.ry": "torad( 20) +if(is_in_water,  sin(torad(30)+var.r+limb_swing/2+age/9 +cos(var.r+limb_swing/2+age/18)/2)/2*clamp(1-limb_speed*6, 0, 1)                                                                      , 0)",
					"left_fin.rz": " torad( 35) +if(is_in_water,  cos(          var.r+limb_swing/2+age/9 +sin(var.r+limb_swing/2+age/18)  )/2*clamp(1-limb_speed*6, 0, 1) +(torad( 20) -sin(var.r+limb_swing+age/12)/3)*clamp(limb_speed*6, 0, 1),  sin(age/1.5)/2)",
					"right_fin.rz": "torad(-35) +if(is_in_water, -sin(          var.r+limb_swing/2+age/9 +cos(var.r+limb_swing/2+age/18)  )/2*clamp(1-limb_speed*6, 0, 1) +(torad(-20) -sin(var.r+limb_swing+age/12)/3)*clamp(limb_speed*6, 0, 1), -sin(age/1.5)/2)"
				},
				{
					"var.y": "var.y2",
					"var.y2": "var.y3",
					"var.y3": "var.y4",
					"var.y4": "var.y5",
					"var.y5": "var.y6",
					"var.y6": "var.y7",
					"var.y7": "var.y8",
					"var.y8": "var.y9",
					"var.y9": "var.y10",
					"var.y10": "pos_y"
				},
